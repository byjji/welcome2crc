rules_version = '2';

// ============================================================
// 당근러닝크루 크루 공간 — Firestore 보안 규칙
// ------------------------------------------------------------
// 역할(role): pending(승인 대기) → member(크루원) → admin(운영진)
// 배포: firebase deploy --only firestore:rules
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role;
    }

    function isMember() {
      return signedIn() && myRole() in ['member', 'admin'];
    }

    function isAdmin() {
      return signedIn() && myRole() == 'admin';
    }

    // ----- 멤버 -----
    // 가입 시 본인 문서를 'pending' 역할로만 생성 가능.
    // 역할 변경(승인/운영진 지정)과 삭제는 운영진만.
    match /members/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isMember());
      allow list: if isMember();
      allow create: if signedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'pending'
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 40;
      // 본인은 이름(name)만 수정 가능, 그 외(역할 변경 등)는 운영진만
      allow update: if isAdmin()
                    || (signedIn()
                        && request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
                        && request.resource.data.name is string
                        && request.resource.data.name.size() > 0
                        && request.resource.data.name.size() <= 40);
      allow delete: if isAdmin();
    }

    // ----- 비밀번호 힌트 (비밀번호 찾기용) -----
    // 로그인 전에 확인해야 하므로 단건 읽기(get)는 공개.
    // 비밀번호는 "답변"으로 암호화되어 있어 문서만 봐서는 알 수 없음.
    // 쓰기는 로그인한 본인 uid 를 담을 때만 가능.
    // (계정을 지웠다 같은 계정으로 재가입하면 uid 가 바뀌므로,
    //  이전 힌트 문서를 새 uid 로 덮어쓸 수 있어야 함)
    match /pwhints/{accountId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ----- 공지 -----
    match /notices/{id} {
      allow read: if isMember();
      allow create, update, delete: if isAdmin();
    }

    // ----- 일정 + 출석체크 -----
    match /events/{eventId} {
      allow read: if isMember();
      allow create, delete: if isAdmin();
      // 앨범 연결(albumId)만 크루원도 갱신 가능
      // (일정 카드에서 첫 사진을 올릴 때 앨범을 만들어 연결 — 갤러리)
      allow update: if isAdmin()
                    || (isMember()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['albumId'])
                        && request.resource.data.albumId is string);

      // 출석 + 러닝 기록(거리·시간): 본인 것만 기록/수정/취소 가능.
      // 운영진은 기록을 대신 입력/수정하거나 정리할 수 있음.
      match /attendance/{uid} {
        allow read: if isMember();
        allow create, update: if isAdmin() || (isMember() && request.auth.uid == uid);
        allow delete: if isAdmin() || (isMember() && request.auth.uid == uid);
      }
    }

    // ----- 마일리지 (기록 보기: 각오·목표·현재 누적 거리) -----
    // 본인 것은 본인이, 운영진은 모두 수정 가능.
    match /mileage/{uid} {
      allow read: if isMember();
      allow create, update: if isAdmin() || (isMember() && request.auth.uid == uid);
      allow delete: if isAdmin();
    }

    // ----- 공개 사이트 콘텐츠 (소개 페이지) -----
    // 소개 페이지(index.html)는 로그인 없이 보므로 누구나 읽기 가능.
    // 수정은 관리자 페이지(admin.html)에서 운영진만.
    match /site/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ----- 크루 공식 기록 (대회별) -----
    match /records/{raceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ----- 갤러리 (앨범 + 사진) -----
    // 크루원은 일정에 연결된 앨범만 생성 가능 — 일정 카드에서 첫 사진을
    // 올릴 때 그 자리에서 앨범을 만들기 위해. 반드시 일정(eventId)과 연결.
    // 일정과 무관한 독립 앨범·앨범 정보 수정·삭제는 운영진만.
    match /albums/{albumId} {
      allow read: if isMember();
      allow create: if isAdmin()
                    || (isMember()
                        && request.resource.data.eventId is string
                        && request.resource.data.title is string);
      // 크루원은 사진을 올리고 지울 때 장수(photoCount)·표지(coverUrl)만 갱신
      allow update: if isAdmin()
                    || (isMember()
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['photoCount', 'coverUrl', 'updatedAt']));
      allow delete: if isAdmin();

      // 사진 메타: 업로드는 본인 것만, 삭제는 본인 + 운영진
      match /photos/{photoId} {
        allow read: if isMember();
        allow create: if isMember() && request.resource.data.uploaderUid == request.auth.uid;
        allow update: if false;
        allow delete: if isAdmin() || (isMember() && resource.data.uploaderUid == request.auth.uid);
      }
    }

    // ----- 투표 -----
    match /polls/{pollId} {
      allow read: if isMember();
      allow create, update, delete: if isAdmin();

      // 투표: 본인 표만 기록/변경 가능
      match /votes/{uid} {
        allow read: if isMember();
        allow create, update: if isMember() && request.auth.uid == uid;
        allow delete: if isAdmin() || (isMember() && request.auth.uid == uid);
      }
    }
  }
}
